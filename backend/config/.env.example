#!/usr/bin/env bash
# StayVanta backend environment variables.
#
# Local dev reads sane defaults from config/app_local.php and does NOT need
# this file. To use it locally, copy to config/.env and uncomment the loader
# in config/bootstrap.php. In production (Railway) set these as real
# environment variables on the service.
#
# Having this file in production is a SECURITY RISK and slows bootstrap.
export APP_NAME="StayVanta"
export DEBUG="false"
export APP_ENCODING="UTF-8"
export APP_DEFAULT_LOCALE="en_US"
export APP_DEFAULT_TIMEZONE="UTC"
# REQUIRED in production: prevents Host Header Injection.
export APP_FULL_BASE_URL="https://api.stayvanta.com"
export SECURITY_SALT="change-me-to-a-long-random-string"

# Railway provides a full MySQL DSN — DATABASE_URL takes precedence over DB_*.
#export DATABASE_URL="mysql://user:pass@host:port/dbname?encoding=utf8&cacheMetadata=true"

# Or discrete connection vars (used when DATABASE_URL is unset):
export DB_HOST="127.0.0.1"
export DB_PORT="3306"
export DB_USERNAME="root"
export DB_PASSWORD=""
export DB_DATABASE="stay_vanta"

# Comma-separated origins allowed to call the API in production (the SPA URL).
export CORS_ORIGINS="https://stayvanta.pages.dev"
